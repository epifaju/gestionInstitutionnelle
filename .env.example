# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion
DB_USER=gestion
DB_PASSWORD=gestion

# JWT RS256 — soit : base64 du fichier PEM complet (openssl base64 -A -in private.pem),
# soit coller le PEM multi-ligne entre guillemets, soit base64 du seul DER PKCS#8 / SPKI.
# Éviter les retours à la ligne au milieu d’une seule chaîne base64 (ou laisser le code les ignorer).
# Sous Docker Compose : si la valeur contient « $ », échappez en « $$ » pour éviter l’interpolation.
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# MinIO (compatible S3)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_BUCKET=gestion
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
#
# Optionnel: overrider l'image MinIO (utile si un volume existant a été créé avec une autre version)
# Exemple: MINIO_IMAGE=minio/minio:latest
MINIO_IMAGE=

# CORS — origine du navigateur (ex. http://localhost sans port si nginx sur 80)
FRONTEND_URL=http://localhost

# Frontend (Docker) — URL publique de l’API (chemin derrière nginx)
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:8080/api

# Cookie refresh HttpOnly : Secure=true requis en HTTPS (production)
REFRESH_COOKIE_SECURE=false
