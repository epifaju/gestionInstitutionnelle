<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Keep Spring test logs readable, but silence Testcontainers/Docker probing noise on machines without Docker. -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Testcontainers docker discovery can be very noisy (ERROR) when Docker isn't running. -->
    <logger name="org.testcontainers" level="OFF"/>
    <logger name="com.github.dockerjava" level="OFF"/>

    <!-- Optional: keep Spring logs at INFO by default. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>

