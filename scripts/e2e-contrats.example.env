# Copier vers scripts/e2e-contrats.env (non versionné) ou exporter ces variables avant d'exécuter les scripts.
# Mot de passe commun des comptes seed (V21) : AdminTest123!

# Base API (sans slash final). Exemples :
#   backend seul : http://localhost:8080/api/v1
#   via nginx    : http://localhost/api/v1
# Si le login renvoie 403, un autre service occupe souvent le port : changer API_BASE ou arrêter le conflit.
API_BASE=http://localhost:8080/api/v1

# Salarié fixture (Flyway V21)
E2E_SALARIE_ID=c0e2e0e0-0000-4000-8000-000000000001

# Connexions (emails créés par V21 ; admin existait déjà dans V1+V3)
E2E_RH_EMAIL=rh@test.com
E2E_RH_PASSWORD=AdminTest123!

E2E_ADMIN_EMAIL=admin@test.com
E2E_ADMIN_PASSWORD=AdminTest123!

E2E_FINANCIER_EMAIL=financier@test.com
E2E_FINANCIER_PASSWORD=AdminTest123!

E2E_EMPLOYE_EMAIL=employe@test.com
E2E_EMPLOYE_PASSWORD=AdminTest123!

# --- Vérification scheduler EXPIREE (hors script) ---
# Aucun endpoint public n’appelle verifierEcheancesQuotidien() : job planifié (lun–ven 7h) ou tests Maven (ContratServiceTest / EcheanceScheduler).
# Pour forcer une échéance expirée en base (PostgreSQL), exemple :
#   INSERT INTO echeances_rh (organisation_id, salarie_id, type_echeance, titre, date_echeance, statut, priorite, rappel_j30_envoye, rappel_j7_envoye, rappel_j0_envoye)
#   SELECT organisation_id, id, 'AUTRE'::type_echeance, 'E2E expirée', CURRENT_DATE - 1, 'EN_ALERTE'::statut_echeance, 2, false, false, false
#   FROM salaries WHERE id = 'c0e2e0e0-0000-4000-8000-000000000001'::uuid;
